# Staff sign-in is a self-issued JWT email/password login (the backend's
# JWT_SECRET). No frontend auth config is required for it.

# Portal origin(s) allowed to deliver a reporter hand-off token via postMessage,
# comma-separated (e.g. https://portal.example.com). Same origin is always
# trusted. Leave blank to accept hand-off only via the ?handoff= query param.
VITE_PORTAL_ORIGINS=
