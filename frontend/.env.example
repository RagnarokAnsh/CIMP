# Staff auth mode: 'local' = self-issued JWT email/password login (pair with the
# backend's JWT_SECRET); unset/empty = OIDC. The dev shim (VITE_DEV_AUTH below)
# overrides both in non-prod.
VITE_AUTH_MODE=

# Staff OIDC (single sign-on) — used when VITE_AUTH_MODE is not 'local'. Leave
# blank to show the "not configured" notice instead of a login screen. The
# reporter surface needs none of this — it uses the portal hand-off token.
VITE_OIDC_AUTHORITY=https://your-idp.example.com/
VITE_OIDC_CLIENT_ID=support-platform-spa
VITE_OIDC_REDIRECT_URI=http://localhost:5173/staff
VITE_OIDC_SCOPE=openid profile email

# Portal origin(s) allowed to deliver a reporter hand-off token via postMessage,
# comma-separated (e.g. https://portal.example.com). Same origin is always
# trusted. Leave blank to accept hand-off only via the ?handoff= query param.
VITE_PORTAL_ORIGINS=

# DEV ONLY: use the local staff login instead of OIDC (pair with DEV_AUTH=true
# in the backend). When true, VITE_OIDC_* is ignored for staff sign-in.
VITE_DEV_AUTH=false
