# Set to "production" in prod. This activates fail-closed config checks
# (see src/config/env.validation.ts): the app refuses to boot if
# DB_SYNCHRONIZE is true, CORS_ORIGINS is "*"/unset, DEV_AUTH is true, or OIDC
# is unconfigured. It also disables the Swagger docs and verbose error output.
NODE_ENV=development
PORT=3000

# Comma-separated allowed frontend origins. MUST be explicit origins in
# production ("*" is rejected at boot when NODE_ENV=production).
CORS_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=support
DB_PASSWORD=support
DB_NAME=support_platform
# Auto-create schema from entities. DEV ONLY — set false and run migrations in production.
DB_SYNCHRONIZE=true

# Storage: 'local' (disk) or 's3' (S3/MinIO).
STORAGE_DRIVER=local
STORAGE_DIR=./uploads
# S3/MinIO (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=support-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Staff authentication ---
# Pick ONE method (the dev shim below also works in non-prod):
#
# (A) Self-issued JWT (no external IdP). Set a strong random JWT_SECRET; the API
#     then mints tokens at POST /api/auth/login and verifies them itself. Pair
#     with VITE_AUTH_MODE=local in frontend/.env. Create staff + passwords via
#     the admin API (POST /api/admin/staff).
JWT_SECRET=
JWT_EXPIRES_IN=8h

# (B) OIDC single sign-on. Tokens are validated against the IdP's JWKS.
OIDC_ISSUER=https://your-idp.example.com/
OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
OIDC_AUDIENCE=support-platform-api
OIDC_NAME_CLAIM=name
OIDC_EMAIL_CLAIM=email

# Rate limiting (per IP). intakeLimit applies to POST /api/reporter/issues.
THROTTLE_TTL=60
THROTTLE_LIMIT=120
THROTTLE_INTAKE_LIMIT=10

# Email (staff notifications). Leave SMTP_HOST blank to log emails instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Support Platform <no-reply@support.local>
APP_URL=http://localhost:5173

# Attachment malware scanning. 'noop' (default; marks files SKIPPED) or 'clamav'
# (streams to a clamd daemon). Production warns if this is not 'clamav'.
SCAN_DRIVER=noop
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000

# Resolution SLA targets (hours from creation) per priority, and the elapsed
# fraction at which an open issue is flagged "at risk". Defaults shown.
SLA_HOURS_CRITICAL=4
SLA_HOURS_HIGH=24
SLA_HOURS_MEDIUM=72
SLA_HOURS_LOW=168
SLA_AT_RISK_FRACTION=0.8

# Jira (two-way). Leave blank to disable. JIRA_WEBHOOK_SECRET gates the inbound
# status webhook at POST /api/integrations/jira/webhook (X-Webhook-Token header).
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# OD-09 policy seam: may focal points change issue status? Default false.
FOCAL_POINT_CAN_TRANSITION=false

# DEV ONLY: local staff login that bypasses OIDC (auto-disabled when
# NODE_ENV=production). Pair with VITE_DEV_AUTH=true in frontend/.env.
DEV_AUTH=false
DEV_AUTH_SECRET=dev-only-not-for-production
