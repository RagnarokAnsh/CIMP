PORT=3000

# Comma-separated allowed frontend origins. Use specific origins in production.
CORS_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=support
DB_PASSWORD=support
DB_NAME=support_platform
# Auto-create schema from entities. DEV ONLY — set false and run migrations in production.
DB_SYNCHRONIZE=true

# Storage: 'local' (disk) or 's3' (S3/MinIO).
STORAGE_DRIVER=local
STORAGE_DIR=./uploads
# S3/MinIO (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=support-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Staff authentication (OIDC). Tokens are validated against the IdP's JWKS.
OIDC_ISSUER=https://your-idp.example.com/
OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
OIDC_AUDIENCE=support-platform-api
OIDC_NAME_CLAIM=name
OIDC_EMAIL_CLAIM=email

# Rate limiting (per IP). intakeLimit applies to POST /api/reporter/issues.
THROTTLE_TTL=60
THROTTLE_LIMIT=120
THROTTLE_INTAKE_LIMIT=10

# Email (staff notifications). Leave SMTP_HOST blank to log emails instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Support Platform <no-reply@support.local>
APP_URL=http://localhost:5173

# Jira (one-way push). Leave blank to disable.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# OD-09 policy seam: may focal points change issue status? Default false.
FOCAL_POINT_CAN_TRANSITION=false

# DEV ONLY: local staff login that bypasses OIDC (auto-disabled when
# NODE_ENV=production). Pair with VITE_DEV_AUTH=true in frontend/.env.
DEV_AUTH=false
DEV_AUTH_SECRET=dev-only-not-for-production
